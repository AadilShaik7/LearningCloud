# Python virtual environment
.venv/

# Python cache files
__pycache__/
*.py[cod]

# Secrets and local settings
.env
.env.*
!.env.example

# VS Code local-only settings
.vscode/*.local.json

# Terraform temporary files and state
.terraform/
*.tfstate
*.tfstate.*
crash.log
crash.*.log

# Terraform variable files can contain secrets later
*.tfvars
*.tfvars.json